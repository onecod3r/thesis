__pycache__/
*.py[oc]
.ipynb_checkpoints/
build/
dist/
wheels/
*.egg-info
.venv
.env

# data tree (src/data/) — raw datasets live in kagglehub's cache or on the
# POPSIGN_LANDMARKS_DRIVE, derived caches in src/data/cache/, scratch in
# src/data/temp/ (deleted after use). None of it enters the repo.
# The one committed subtree is the model registry (src/data/models/):
# index.csv + per-run meta.json + assets/ are tracked, weights (*.pt) are not.
src/data/*
!src/data/models/
src/data/models/**/*.pt
src/data/models/*/export/

# model-export artifacts (TFLite chain: ONNX → TF SavedModel → TFLite)
*.onnx
*.tflite
src/saved_model_dir/
src/final_saved_model/
